{
  "uid": "gaia-host",
  "title": "gaia \u2014 Host & RT",
  "tags": [
    "gaia"
  ],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU busy % per core",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 - (avg by(cpu)(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "cpu{{cpu}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory used %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "used %"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Load average",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_load1",
          "legendFormat": "1m"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_load5",
          "legendFormat": "5m"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_load15",
          "legendFormat": "15m"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network throughput",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[1m])",
          "legendFormat": "rx {{device}}"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[1m])",
          "legendFormat": "tx {{device}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Disk IO utilization",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_disk_io_time_seconds_total[1m])",
          "legendFormat": "{{device}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RT cores 10-13 \u2014 runqueue wait (s/s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(node_schedstat_waiting_seconds_total{cpu=~\"1[0-3]\"}[1m])",
          "legendFormat": "cpu{{cpu}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "RT cores 10-13 \u2014 IRQ rate (want ~0 device IRQs)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by(cpu) (rate(node_interrupts_total{cpu=~\"1[0-3]\"}[1m]))",
          "legendFormat": "cpu{{cpu}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "RAM (used / available / total)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "pointSize": 5,
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {
              "type": "linear"
            },
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "total"
        }
      ]
    }
  ]
}