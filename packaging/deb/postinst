#!/bin/sh
set -e

case "$1" in
  configure)
    # Defensive: ensure scripts are executable even if a tarball-based
    # build path stripped the mode bits.
    if [ -d /opt/Phantom-OS-KubernetesOptions/scripts ]; then
      find /opt/Phantom-OS-KubernetesOptions/scripts \
        -type f \( -name '*.sh' -o -name '*.py' \) \
        -exec chmod 0755 {} +
    fi

    cat <<'EOF'

phantomos-k0s installed at /opt/Phantom-OS-KubernetesOptions

Next steps on a fresh robot:
  sudo bash /opt/Phantom-OS-KubernetesOptions/scripts/configure-host.sh
  sudo bash /opt/Phantom-OS-KubernetesOptions/scripts/bootstrap-robot.sh

Per-host config lives at /etc/phantomos/host-config.yaml and is NOT
managed by this package -- it is generated by configure-host.sh.

EOF
    ;;
  abort-upgrade|abort-remove|abort-deconfigure)
    ;;
  *)
    echo "postinst called with unknown argument \`$1'" >&2
    exit 1
    ;;
esac

exit 0
